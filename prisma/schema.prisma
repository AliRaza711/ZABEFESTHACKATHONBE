generator client {
  provider   = "prisma-client-js"
  engineType = "library" 
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  PENDING
  IN_PROGRESS
  RESOLVED
}

model PotholeReport {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  severity  Severity
  status    Status   @default(PENDING)
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
